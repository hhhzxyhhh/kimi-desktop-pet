{
  "name": "kimi-desktop-pet",
  "version": "0.2.0",
  "description": "非官方 Kimi 小蓝球桌宠——住在你的桌面上",
  "main": "main.js",
  "author": "张馨月",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "test": "node test-hook.cjs",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^31.7.0",
    "electron-builder": "^24.13.3"
  },
  "build": {
    "appId": "com.kimi.pet",
    "productName": "Kimi桌宠",
    "files": [
      "main.js",
      "agent-hook.cjs",
      "preload.js",
      "index.html",
      "pet-hook.cjs",
      "assets"
    ],
    "mac": {
      "category": "public.app-category.entertainment",
      "icon": "assets/icon.png"
    },
    "win": {
      "target": "portable",
      "icon": "assets/icon.png"
    }
  }
}
